<!-- PINCODE CHECKER -->
<section class="section-light" id="pincode">
  <div class="section-center">
    <div class="section-label">Serviceability Check</div>
    <h2>Delivery Possible Kya?</h2>
    <p class="section-sub">Pincode enter karo — turant check hoga Delhivery network se.</p>
    <div class="pin-row">
      <input type="number" id="pin-input" placeholder="6-digit pincode e.g. 400001" maxlength="6" oninput="this.value=this.value.slice(0,6)"/>
      <button class="btn-primary" onclick="checkPin()">Check →</button>
    </div>
    <div id="pin-result" class="pin-result" style="display:none"></div>
    <div class="quick-pins">
      <span onclick="quickPin('732101')">📍 Malda 732101</span>
      <span onclick="quickPin('400001')">🏙️ Mumbai 400001</span>
      <span onclick="quickPin('110001')">🏛️ Delhi 110001</span>
      <span onclick="quickPin('560001')">🌿 Bangalore 560001</span>
      <span onclick="quickPin('700001')">🐟 Kolkata 700001</span>
    </div>
  </div>
</section>

