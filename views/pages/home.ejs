<!-- CTA BANNER -->
<section class="cta-banner">
  <div class="cta-content">
    <h2>Ready to Ship?</h2>
    <p>Ab SmitaLogistic ke through apna parcel bhejo — fast, safe, tracked.</p>
    <div class="hero-btns" style="justify-content:center">
      <a href="/book" class="btn-primary">📦 Book Now — Free Pickup</a>
      <a href="/contact" class="btn-outline-white">📞 Contact Us</a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>

<script>
function checkPin(){
  const pin = document.getElementById('pin-input').value.trim();
  const res = document.getElementById('pin-result');
  if(!pin||pin.length!==6){ showPinResult('error','⚠️ Valid 6-digit pincode daalo.'); return; }
  showPinResult('loading','⏳ Checking Delhivery network...');
  fetch(`/api/pincode?pin=${pin}`)
    .then(r=>r.json())
    .then(d=>{
      if(d.deliverable){
        showPinResult('ok',`✅ <strong>${d.city}, ${d.state}</strong> — Delivery available! ${d.cod?'💵 COD':''}  ${d.prepaid?'💳 Prepaid':''}`);
      } else {
        showPinResult('error',`❌ Pincode ${pin} — Delivery abhi available nahi.`);
      }
    }).catch(()=>showPinResult('error','⚠️ Server error. Try again.'));
}
function showPinResult(type, html){
  const el = document.getElementById('pin-result');
  el.className = 'pin-result pin-'+type;
  el.innerHTML = html;
  el.style.display='block';
}
function quickPin(p){ document.getElementById('pin-input').value=p; checkPin(); }
document.getElementById('pin-input').addEventListener('keypress',e=>{ if(e.key==='Enter') checkPin(); });
</script>
