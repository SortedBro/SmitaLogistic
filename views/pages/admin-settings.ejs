<%- include('../partials/head') %>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">

    <div class="admin-topbar">
      <h1>⚙️ Settings</h1>
    </div>

    <%- include('../partials/flash') %>

    <form action="/admin/settings" method="POST">
      <div class="settings-grid">

        <!-- ── PRICING / MARGIN ── -->
        <div class="admin-card">
          <div class="ac-header">
            <h3>💰 Pricing & Margin</h3>
            <span style="font-size:.78rem;color:var(--muted)">Global default — har order pe apply</span>
          </div>
          <div style="padding:24px">

            <!-- Formula display -->
            <div class="formula-box">
              <div class="formula-title">📐 Formula</div>
              <div class="formula-eq">
                Final Price = Delhivery Cost + Fixed Margin + (Delhivery Cost × Percentage%)
              </div>
              <div class="formula-example" id="formula-live">
                e.g. ₹95 + ₹<span id="ex-fixed">50</span> + (₹95 × <span id="ex-pct">0</span>%) = ₹<span id="ex-total">145</span>
              </div>
            </div>

            <div class="form-row-2" style="margin-top:20px">
              <div class="fg">
                <label>Fixed Margin (₹) <span style="color:var(--muted);font-weight:400;font-size:.75rem">— har order pe fixed profit</span></label>
                <input type="number" name="fixedMargin" id="inp-fixed"
                  value="<%= settings.fixedMargin ?? 50 %>"
                  placeholder="50" min="0" oninput="updateFormula()"/>
                <div style="font-size:.75rem;color:var(--muted);margin-top:4px">
                  e.g. ₹50 daalo → har order pe ₹50 tumhara
                </div>
              </div>
              <div class="fg">
                <label>Percentage Margin (%) <span style="color:var(--muted);font-weight:400;font-size:.75rem">— Delhivery rate ka %</span></label>
                <input type="number" name="pctMargin" id="inp-pct"
                  value="<%= settings.pctMargin ?? 0 %>"
                  placeholder="0" min="0" max="200" step="0.5" oninput="updateFormula()"/>
                <div style="font-size:.75rem;color:var(--muted);margin-top:4px">
                  e.g. 20% daalo → ₹95 Delhivery cost pe ₹19 extra
                </div>
              </div>
            </div>

            <!-- Live examples table -->
            <div style="margin-top:20px">
              <div style="font-size:.78rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px">Live Preview — Tumhara Margin</div>
              <table class="margin-preview-table" id="margin-table">
                <thead>
                  <tr>
                    <th>Weight</th>
                    <th>Delhivery Cost</th>
                    <th>Tumhara Margin</th>
                    <th>Customer se Lo</th>
                    <th>Tumhara Profit</th>
                  </tr>
                </thead>
                <tbody id="margin-tbody">
                  <!-- JS se fill hoga -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ── BUSINESS INFO ── -->
        <div class="admin-card" style="margin-top:20px">
          <div class="ac-header"><h3>🏢 Business Info</h3></div>
          <div style="padding:24px">
            <div class="form-row-2">
              <div class="fg">
                <label>Business Name</label>
                <input type="text" name="businessName"
                  value="<%= settings.businessName ?? 'SmitaLogistic' %>"
                  placeholder="SmitaLogistic"/>
              </div>
              <div class="fg">
                <label>Admin Phone (WhatsApp)</label>
                <input type="tel" name="adminPhone"
                  value="<%= settings.adminPhone ?? '' %>"
                  placeholder="8167045246"/>
              </div>
            </div>
            <div class="fg">
              <label>CallMeBot WhatsApp API Key</label>
              <input type="text" name="whatsappApiKey"
                value="<%= settings.whatsappApiKey ?? '' %>"
                placeholder="Aapka CallMeBot API key"/>
              <div style="font-size:.75rem;color:var(--muted);margin-top:4px">
                Setup: callmebot.com — Free WhatsApp notifications
              </div>
            </div>
          </div>
        </div>

      </div>

      <div style="margin-top:20px">
        <button type="submit" class="btn-primary" style="padding:14px 40px;font-size:1rem">
          💾 Save Settings
        </button>
      </div>
    </form>

  </main>
</div>

<script>
const COSTS = [
  { label: '0.5 kg',  cost: 55  },
  { label: '1 kg',    cost: 70  },
  { label: '2 kg',    cost: 95  },
  { label: '3 kg',    cost: 120 },
  { label: '5 kg',    cost: 160 },
  { label: '10 kg',   cost: 220 },
  { label: '20 kg',   cost: 350 },
];

function updateFormula() {
  const fixed = parseFloat(document.getElementById('inp-fixed').value) || 0;
  const pct   = parseFloat(document.getElementById('inp-pct').value)   || 0;

  // Update formula example
  const exCost  = 95;
  const exPctAmt = Math.ceil(exCost * pct / 100);
  const exTotal  = Math.ceil(exCost + fixed + exPctAmt);

  document.getElementById('ex-fixed').textContent = fixed;
  document.getElementById('ex-pct').textContent   = pct;
  document.getElementById('ex-total').textContent = exTotal;

  // Update preview table
  const tbody = document.getElementById('margin-tbody');
  tbody.innerHTML = COSTS.map(row => {
    const pctAmt  = Math.ceil(row.cost * pct / 100);
    const margin  = fixed + pctAmt;
    const charge  = Math.ceil(row.cost + margin);
    const profit  = margin;
    return `<tr>
      <td>${row.label}</td>
      <td style="color:var(--blue)">₹${row.cost}</td>
      <td style="color:var(--gold)">₹${fixed} + ₹${pctAmt} = <strong>₹${margin}</strong></td>
      <td style="color:var(--accent);font-weight:700">₹${charge}</td>
      <td style="color:var(--green);font-weight:600">₹${profit}</td>
    </tr>`;
  }).join('');
}

// Run on load
updateFormula();
</script>

</body></html>
