<aside class="admin-sidebar">
  <a href="/" class="admin-logo">Smita<span>Logistic</span><small>Admin Panel</small></a>
  <nav class="admin-nav">
    <a href="/admin"          class="admin-nav-link"><span>📊</span> Dashboard</a>
    <a href="/admin/orders"   class="admin-nav-link"><span>📦</span> All Orders</a>
    <a href="/admin/messages" class="admin-nav-link"><span>💬</span> Messages</a>
    <a href="/admin/settings" class="admin-nav-link"><span>⚙️</span> Settings</a>
    <hr style="border-color:var(--border);margin:12px 0"/>
    <a href="/" class="admin-nav-link" target="_blank"><span>🌐</span> View Website</a>

    <!-- Theme Toggle in sidebar -->
    <button class="sidebar-theme-toggle" onclick="toggleTheme()" id="sidebar-theme-btn">
      <span id="sidebar-theme-icon">🌙</span>
      <span id="sidebar-theme-label">Light Mode</span>
    </button>

    <a href="/admin/logout" class="admin-nav-link admin-nav-danger"><span>🚪</span> Logout</a>
  </nav>
</aside>

<script>
// Update sidebar button label based on current theme
(function updateSidebarBtn() {
  const t     = localStorage.getItem('sl-theme') || 'dark';
  const icon  = document.getElementById('sidebar-theme-icon');
  const label = document.getElementById('sidebar-theme-label');
  if (!icon || !label) return;
  if (t === 'dark') {
    icon.textContent  = '☀️';
    label.textContent = 'Light Mode';
  } else {
    icon.textContent  = '🌙';
    label.textContent = 'Dark Mode';
  }
})();

// Patch toggleTheme to also update sidebar button
const _origToggle = window.toggleTheme;
window.toggleTheme = function() {
  if (_origToggle) _origToggle();
  setTimeout(() => {
    const t     = localStorage.getItem('sl-theme') || 'dark';
    const icon  = document.getElementById('sidebar-theme-icon');
    const label = document.getElementById('sidebar-theme-label');
    if (icon && label) {
      icon.textContent  = t === 'dark' ? '☀️' : '🌙';
      label.textContent = t === 'dark' ? 'Light Mode' : 'Dark Mode';
    }
  }, 50);
};
</script>
