<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <% success.forEach(msg => { %>
    <div class="flash flash-success">✅ <%= msg %></div>
  <% }) %>
<% } %>

<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <% error.forEach(msg => { %>
    <div class="flash flash-error">❌ <%= msg %></div>
  <% }) %>
<% } %>
